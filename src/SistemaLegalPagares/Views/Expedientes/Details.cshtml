@model SistemaLegalPagares.Models.Expediente
@{
    ViewData["Title"] = $"Expediente {Model.NumeroExpediente}";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1>Expediente @Model.NumeroExpediente</h1>
        <p class="text-muted mb-0">Información general del expediente legal</p>
    </div>
    <a asp-action="Index" class="btn btn-secondary">Volver</a>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header">Datos del Expediente</div>
            <div class="card-body">
                <p><strong>Número de expediente:</strong> @Model.NumeroExpediente</p>
                <p><strong>Fecha de creación:</strong> @Model.FechaCreacion.ToLocalTime().ToString("dd/MM/yyyy")</p>
                <p><strong>Observaciones:</strong> @(string.IsNullOrWhiteSpace(Model.Observaciones) ? "No se realizó el pago correspondiente." : Model.Observaciones)</p>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header">Cliente Asociado</div>
            <div class="card-body">
            @if (Model.Cliente is null)
            {
                <p class="text-muted">Sin cliente asociado.</p>
            }
            else
            {
                <p><strong>Nombre completo:</strong> @Model.Cliente.NombreCompleto</p>
                <p><strong>RFC:</strong> @Model.Cliente.RFC</p>
                <p><strong>CURP:</strong> @Model.Cliente.CURP</p>
                <p><strong>INE:</strong> @Model.Cliente.INE</p>
                <p><strong>Teléfono:</strong> @Model.Cliente.Telefono</p>
                <p><strong>Correo:</strong> @Model.Cliente.Correo</p>
                <p><strong>Dirección:</strong> @Model.Cliente.Direccion</p>
            }
            </div>
        </div>
    </div>
</div>

<div class="card mt-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Pagarés del Expediente</span>
        <div>
            <a asp-controller="Pagares" asp-action="Create" asp-route-expedienteId="@Model.Id" class="btn btn-primary btn-sm">Crear Pagaré</a>
            <a asp-action="ImprimirPagares" asp-route-id="@Model.Id" class="btn btn-success btn-sm">Imprimir todos</a>
        </div>
    </div>
    <table class="table mb-0">
        <thead><tr><th>No. Pagaré</th><th>Acreedor</th><th>Monto Total</th><th>Fecha Expedición</th><th>Serie</th><th>Acciones</th></tr></thead>
        <tbody>
        @if (!Model.Pagares.Any())
        {
            <tr><td colspan="6" class="text-center text-muted">Aún no hay pagarés registrados para este expediente.</td></tr>
        }
        @foreach (var p in Model.Pagares)
        {
            <tr>
                <td>@p.Id</td>
                <td>@p.Acreedor</td>
                <td>$@p.MontoTotal.ToString("N2")</td>
                <td>@p.FechaExpedicion.ToLocalTime().ToString("dd/MM/yyyy")</td>
                <td>@p.SerieDesde - @p.SerieHasta</td>
                <td>
                    <a asp-controller="Pagares" asp-action="Details" asp-route-id="@p.Id" class="btn btn-info btn-sm">Ver</a>
                    <a asp-controller="Pagares" asp-action="Pdf" asp-route-id="@p.Id" class="btn btn-outline-success btn-sm">PDF</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

<div class="mt-3 d-flex justify-content-between">
    <a asp-action="Index" class="btn btn-secondary">Volver a expedientes</a>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Editar Expediente</a>
</div>

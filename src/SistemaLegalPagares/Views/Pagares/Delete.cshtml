@model SistemaLegalPagares.Models.Pagare
@{
    ViewData["Title"] = "Eliminar Pagaré";
}

<h1 class="text-danger">Eliminar Pagaré</h1>
<p>¿Seguro que deseas eliminar el pagaré #@Model.Id del expediente <strong>@Model.Expediente?.NumeroExpediente</strong>?</p>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <a asp-controller="Expedientes" asp-action="Details" asp-route-id="@Model.ExpedienteId" class="btn btn-secondary">Cancelar</a>
    <button type="submit" class="btn btn-danger">Eliminar</button>
</form>

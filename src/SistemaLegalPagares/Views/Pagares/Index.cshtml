@model IEnumerable<SistemaLegalPagares.Models.Pagare>
@{
    ViewData["Title"] = "Pagarés";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Pagarés</h1>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Expediente</th><th>Monto</th><th>Beneficiario</th><th>Suscriptor</th>
            <th>Fecha Vencimiento</th>
            @if (User.IsInRole("Admin"))
            {
                <th>Abogado</th>
            }
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var p in Model)
    {
        <tr>
            <td>@(p.Expediente?.NumeroExpediente ?? "EXP-TEMP")</td>
            <td>$@p.MontoTotal.ToString("N2")</td>
            <td>@p.Beneficiario</td>
            <td>@p.Acreedor</td>
            <td>@p.FechaVencimiento.ToString("yyyy-MM-dd")</td>
            @if (User.IsInRole("Admin"))
            {
                <td>@p.Usuario?.NombreCompleto</td>
            }
            <td>
                <a asp-action="Details" asp-route-id="@p.Id" class="btn btn-info btn-sm">Ver pagaré</a>
                <a asp-action="Pdf" asp-route-id="@p.Id" class="btn btn-success btn-sm" target="_blank">Imprimir</a>
            </td>
        </tr>
    }
    </tbody>
</table>
